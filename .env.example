# ── AyNesil Platform Environment Variables ──────────────────────────────────
# Copy to .env and fill in real values before running.
# NEVER commit .env to source control.

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=aynesil
POSTGRES_USER=aynesil_owner
POSTGRES_PASSWORD=changeme_owner
AYNESIL_DB_APP_USER=aynesil_app
AYNESIL_DB_APP_PASSWORD=changeme_app

# ── Connection Strings (used by the API) ─────────────────────────────────────
# App role (subject to RLS) — used at runtime
AYNESIL_ConnectionStrings__DefaultConnection=Host=aynesil-db;Port=5432;Database=aynesil;Username=aynesil_app;Password=changeme_app;Application Name=AynesilApi
# Owner role (bypasses RLS) — used only for migrations
AYNESIL_ConnectionStrings__MigrationConnection=Host=aynesil-db;Port=5432;Database=aynesil;Username=aynesil_owner;Password=changeme_owner

# ── Redis ─────────────────────────────────────────────────────────────────────
AYNESIL_ConnectionStrings__Redis=aynesil-redis:6379,abortConnect=false

# ── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Use at least 64 random characters in production!
AYNESIL_Jwt__Secret=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARACTERS
AYNESIL_Jwt__Issuer=https://api.aynesil.com
AYNESIL_Jwt__Audience=aynesil-web
AYNESIL_Jwt__AccessTokenExpiryMinutes=60
AYNESIL_Jwt__RefreshTokenExpiryDays=30

# ── CORS ─────────────────────────────────────────────────────────────────────
AYNESIL_Cors__AllowedOrigins__0=http://localhost:5173
AYNESIL_Cors__AllowedOrigins__1=https://app.aynesil.com

# ── Storage ──────────────────────────────────────────────────────────────────
AYNESIL_Storage__Local__RootPath=/app/uploads
AYNESIL_Storage__Local__BaseUrl=http://localhost:5000/files

# ── Serilog ──────────────────────────────────────────────────────────────────
AYNESIL_Serilog__MinimumLevel__Default=Information

# ── API ports ─────────────────────────────────────────────────────────────────
API_PORT=5000
FRONTEND_PORT=5173
